---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { AUTHOR, SITE_URL } from "../../consts";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<BaseLayout
  title={`${post.data.title} — ${AUTHOR}`}
  description={post.data.description}
  image={`/og/${post.id}.png`}
  ogType="article"
  pubDate={post.data.pubDate}
>
  <script
    is:inline
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline: post.data.title,
      image: `${SITE_URL}/og/${post.id}.png`,
      datePublished: post.data.pubDate.toISOString(),
      dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
      author: {
        "@type": "Person",
        name: AUTHOR,
        url: SITE_URL,
      },
      url: `${SITE_URL}/blog/${post.id}/`,
    })}
  />
  <article>
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/blog">← Writing</a>
    </nav>

    <header class="post-header">
      <h1 transition:name={`post-title-${post.id}`}>{post.data.title}</h1>
      <div class="post-meta">
        <time datetime={post.data.pubDate.toISOString()}>
          {formatDate(post.data.pubDate)}
        </time>
        {
          post.data.tags && post.data.tags.length > 0 && (
            <ul class="tags" aria-label="Tags">
              {post.data.tags.map((tag) => (
                <li>
                  <a class="tag" href={`/blog/tag/${encodeURIComponent(tag)}`}>
                    {tag}
                  </a>
                </li>
              ))}
            </ul>
          )
        }
        <button
          class="share-btn"
          data-url={Astro.url.href}
          data-title={post.data.title}
          data-text={post.data.description}
          aria-label="Share this post"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"></path>
            <polyline points="16 6 12 2 8 6"></polyline>
            <line x1="12" y1="2" x2="12" y2="15"></line>
          </svg>
          <span class="share-label">Share</span>
        </button>
      </div>
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  article {
    padding-top: clamp(2rem, 6vw, 3.5rem);
    padding-bottom: 2rem;
  }

  .breadcrumb {
    margin-bottom: clamp(3rem, 6vw, 5rem);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    animation: fade-up 350ms ease-out both;
  }

  .breadcrumb a {
    color: var(--muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .breadcrumb a:hover {
    color: var(--fg);
  }

  .post-header {
    margin-bottom: clamp(2rem, 6vw, 3rem);
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 2.8rem);
    font-weight: 500;
    font-style: italic;
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin-bottom: 1rem;
    animation: fade-up 350ms ease-out both;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    animation: fade-up 350ms ease-out 120ms both;
  }

  time {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted);
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    list-style: none;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--muted);
    border: 1px solid var(--border);
    padding: 0.05em 0.7em;
    border-radius: 5px;
    letter-spacing: 0.03em;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .tag:hover {
    color: var(--fg);
  }

  .prose {
    animation: fade-up 350ms ease-out 200ms both;
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: color 0.15s ease;
  }

  .share-btn:hover {
    color: var(--fg);
  }

  .share-btn svg {
    width: 13px;
    height: 13px;
    flex-shrink: 0;
  }
</style>

<script>
  const btn = document.querySelector<HTMLButtonElement>(".share-btn");
  btn?.addEventListener("click", async () => {
    const { url, title, text } = btn.dataset as Record<string, string>;
    if (navigator.share) {
      try {
        await navigator.share({ title, text, url });
      } catch (e) {
        if ((e as DOMException).name !== "AbortError") {
          await copyLink(btn, url);
        }
      }
    } else {
      await copyLink(btn, url);
    }
  });

  async function copyLink(btn: HTMLButtonElement, url: string) {
    await navigator.clipboard.writeText(url);
    const label = btn.querySelector(".share-label")!;
    label.textContent = "Copied!";
    setTimeout(() => {
      label.textContent = "Share";
    }, 1500);
  }
</script>
