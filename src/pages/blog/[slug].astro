---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<BaseLayout
  title={`${post.data.title} — Uriel Spiridione`}
  description={post.data.description}
>
  <article>
    <nav class="breadcrumb">
      <a href="/blog">← Writing</a>
    </nav>

    <header class="post-header">
      <h1 transition:name={`post-title-${post.id}`}>{post.data.title}</h1>
      <div class="post-meta">
        <time datetime={post.data.pubDate.toISOString()}>
          {formatDate(post.data.pubDate)}
        </time>
        {
          post.data.tags && post.data.tags.length > 0 && (
            <ul class="tags" aria-label="Tags">
              {post.data.tags.map((tag) => (
                <li class="tag">{tag}</li>
              ))}
            </ul>
          )
        }
      </div>
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  article {
    padding-top: clamp(2rem, 6vw, 3.5rem);
    padding-bottom: 2rem;
  }

  .breadcrumb {
    margin-bottom: clamp(3rem, 6vw, 5rem);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    animation: fade-up 350ms ease-out both;
  }

  .breadcrumb a {
    color: var(--muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .breadcrumb a:hover {
    color: var(--fg);
  }

  .post-header {
    margin-bottom: clamp(2rem, 6vw, 3rem);
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 2.8rem);
    font-weight: 500;
    font-style: italic;
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin-bottom: 1rem;
    animation: fade-up 350ms ease-out both;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    animation: fade-up 350ms ease-out 120ms both;
  }

  time {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted);
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    list-style: none;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--muted);
    border: 1px solid var(--border);
    padding: 0.05em 0.7em;
    border-radius: 5px;
    letter-spacing: 0.03em;
  }

  .prose {
    animation: fade-up 350ms ease-out 200ms both;
  }
</style>
