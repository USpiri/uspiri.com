---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { AUTHOR, SITE_URL } from "../../consts";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

const years = [...new Set(posts.map((p) => p.data.pubDate.getFullYear()))];
const ldposts = posts.map((post) => ({
  "@type": "BlogPosting",
  headline: post.data.title,
  url: `${SITE_URL}/blog/${post.id}/`,
  datePublished: post.data.pubDate.toISOString(),
}));
---

<BaseLayout
  title={`Writing — ${AUTHOR}`}
  description={`All writing by ${AUTHOR} — web development, frontend engineering, software, and the occasional rabbit hole.`}
>
  <script
    is:inline
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Blog",
      name: `Writing — ${AUTHOR}`,
      url: `${SITE_URL}/blog`,
      author: {
        "@type": "Person",
        name: AUTHOR,
        url: SITE_URL,
      },
      blogPost: ldposts,
    })}
  />
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">{AUTHOR}</a>
    <span aria-hidden="true">·</span>
    <span>Writing</span>
  </nav>

  <section class="posts">
    <h1 class="sr-only">Writing</h1>
    {
      years.map((year) => (
        <div class="year-group">
          <span class="year-label">{year}</span>
          <ol class="post-list">
            {posts
              .filter((p) => p.data.pubDate.getFullYear() === year)
              .map((post) => (
                <li class="post-item">
                  <a
                    href={`/blog/${post.id}`}
                    class="post-title"
                    transition:name={`post-title-${post.id}`}
                  >
                    {post.data.title}
                  </a>
                  <time
                    class="post-date"
                    datetime={post.data.pubDate.toISOString()}
                  >
                    {formatDate(post.data.pubDate)}
                  </time>
                </li>
              ))}
          </ol>
        </div>
      ))
    }
  </section>
</BaseLayout>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding-top: clamp(2rem, 6vw, 3.5rem);
    margin-bottom: clamp(2.5rem, 7vw, 4rem);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted);
    animation: fade-up 350ms ease-out both;
  }

  .breadcrumb a {
    color: var(--muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .breadcrumb a:hover {
    color: var(--fg);
  }

  .breadcrumb span:last-child {
    color: var(--fg);
  }

  .posts {
    padding-bottom: 2rem;
  }

  .year-group {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 0 1.5rem;
    margin-bottom: 0.5rem;
    animation: fade-up 350ms ease-out both;
  }

  .year-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted);
    padding-top: 1.1rem;
    letter-spacing: 0.03em;
  }

  .post-list {
    list-style: none;
    flex: 1;
  }

  .post-item {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--border);
  }

  .post-item:first-child {
    border-top: 1px solid var(--border);
  }

  .post-title {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 400;
    text-decoration: none;
    color: var(--fg);
    transition: color 0.15s ease;
    line-height: 1.3;
  }

  .post-title:hover {
    color: var(--muted);
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .year-group {
      grid-template-columns: 1fr;
    }

    .post-item {
      flex-direction: column-reverse;
      align-items: flex-start;
      gap: 0.3rem;
    }
  }
</style>
