---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { AUTHOR, EMPLOYER } from "../consts";

const allPosts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const posts = allPosts.slice(0, 10);

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<BaseLayout title={AUTHOR}>
  <section class="intro">
    <h1>{AUTHOR}</h1>
    <p>
      Fullstack developer from Argentina. Building for the web at
      <a href={EMPLOYER.url} target="_blank" rel="noopener noreferrer"
        >{EMPLOYER.name}</a
      > — five years deep in front-end, now all the way through the stack.
    </p>
  </section>

  <section class="posts">
    <header class="posts-header">
      <span class="label">Writing</span>
      {allPosts.length > 10 && <a href="/blog">All posts →</a>}
    </header>
    <ol class="post-list">
      {
        posts.slice(0, 10).map((post) => (
          <li class="post-item">
            <a
              href={`/blog/${post.id}`}
              class="post-title"
              transition:name={`post-title-${post.id}`}
            >
              {post.data.title}
            </a>
            <time class="post-date" datetime={post.data.pubDate.toISOString()}>
              {formatDate(post.data.pubDate)}
            </time>
          </li>
        ))
      }
    </ol>
    <p class="post-count">
      <span class="label">{posts.length}/{allPosts.length}</span>
    </p>
  </section>
</BaseLayout>

<style>
  .intro {
    padding-top: clamp(5rem, 10vw, 6rem);
    padding-bottom: clamp(2.5rem, 7vw, 4rem);
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 6vw, 3.2rem);
    font-weight: 400;
    font-style: italic;
    line-height: 1.1;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
    animation: fade-up 400ms ease-out both;
  }

  .intro p {
    font-size: 0.925rem;
    color: var(--muted);
    max-width: 69ch;
    line-height: 1.7;
    animation: fade-up 400ms ease-out 100ms both;
  }

  .intro p a {
    color: var(--fg);
    text-decoration-color: var(--border);
    font-weight: 500;
  }

  .intro p a:hover {
    text-decoration-color: var(--fg);
  }

  .posts {
    padding-bottom: 2rem;
  }

  .posts-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
    animation: fade-up 400ms ease-out 200ms both;
  }

  .post-count {
    width: 100%;
    text-align: right;
    margin-top: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted);
    animation: fade-up 400ms ease-out 350ms both;
  }

  .label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .posts-header a {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .posts-header a:hover {
    color: var(--fg);
  }

  .post-list {
    list-style: none;
  }

  .post-item {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--border);
    animation: fade-up 300ms ease-out both;
  }

  .post-item:nth-child(1) {
    animation-delay: 260ms;
  }
  .post-item:nth-child(2) {
    animation-delay: 295ms;
  }
  .post-item:nth-child(3) {
    animation-delay: 330ms;
  }
  .post-item:nth-child(4) {
    animation-delay: 365ms;
  }
  .post-item:nth-child(5) {
    animation-delay: 400ms;
  }
  .post-item:nth-child(6) {
    animation-delay: 435ms;
  }
  .post-item:nth-child(7) {
    animation-delay: 470ms;
  }
  .post-item:nth-child(8) {
    animation-delay: 505ms;
  }
  .post-item:nth-child(9) {
    animation-delay: 540ms;
  }
  .post-item:nth-child(10) {
    animation-delay: 575ms;
  }

  .post-title {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 400;
    text-decoration: none;
    color: var(--fg);
    transition: color 0.15s ease;
    line-height: 1.3;
  }

  .post-title:hover {
    color: var(--muted);
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted);
    white-space: nowrap;
    flex-shrink: 0;
  }
</style>
