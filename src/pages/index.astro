---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 10);

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<BaseLayout title="Uriel Spiridione">
  <section class="intro">
    <h1>Uriel Spiridione</h1>
    <p>
      Fullstack developer from Argentina. Building for the web at
      <a href="https://honra.io" target="_blank" rel="noopener noreferrer"
        >Honra.io</a
      > — five years deep in front-end, now all the way through the stack.
    </p>
  </section>

  <section class="posts">
    <header class="posts-header">
      <span class="label">Writing</span>
      {posts.length > 10 && <a href="/blog">All posts →</a>}
    </header>
    <ol class="post-list">
      {
        posts.slice(0, 10).map((post) => (
          <li class="post-item">
            <a href={`/blog/${post.id}`} class="post-title">
              {post.data.title}
            </a>
            <time class="post-date" datetime={post.data.pubDate.toISOString()}>
              {formatDate(post.data.pubDate)}
            </time>
          </li>
        ))
      }
    </ol>
  </section>
</BaseLayout>

<style>
  .intro {
    padding-top: clamp(3.5rem, 10vw, 6rem);
    padding-bottom: clamp(2.5rem, 7vw, 4rem);
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 6vw, 3.2rem);
    font-weight: 400;
    font-style: italic;
    line-height: 1.1;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
  }

  .intro p {
    font-size: 0.925rem;
    color: var(--muted);
    max-width: 69ch;
    line-height: 1.7;
  }

  .intro p a {
    color: var(--fg);
    text-decoration-color: var(--border);
    font-weight: 500;
  }

  .intro p a:hover {
    text-decoration-color: var(--fg);
  }

  .posts {
    padding-bottom: 2rem;
  }

  .posts-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  .label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .posts-header a {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .posts-header a:hover {
    color: var(--fg);
  }

  .post-list {
    list-style: none;
  }

  .post-item {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--border);
  }

  .post-title {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 400;
    text-decoration: none;
    color: var(--fg);
    transition: color 0.15s ease;
    line-height: 1.3;
  }

  .post-title:hover {
    color: var(--muted);
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted);
    white-space: nowrap;
    flex-shrink: 0;
  }
</style>
