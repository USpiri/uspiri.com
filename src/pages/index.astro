---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { AUTHOR, EMPLOYER } from "../consts";
import { WORK } from "../data/work";
import { PROJECTS } from "../data/projects";

const allPosts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const posts = allPosts.slice(0, 10);

const projectsHeaderDelay = 180 + WORK.length * 40 + 20;
const postsHeaderDelay = 180 + WORK.length * 40 + PROJECTS.length * 35 + 60;

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<BaseLayout title={AUTHOR}>
  <section class="intro">
    <h1>{AUTHOR}</h1>
    <p>
      Fullstack developer from Argentina. Building for the web at
      <a href={EMPLOYER.url} target="_blank" rel="noopener noreferrer"
        >{EMPLOYER.name}</a
      > — five years deep in front-end, now all the way through the stack.
    </p>
  </section>

  <section class="work">
    <header class="work-header">
      <span class="label">Experience</span>
    </header>
    <ol class="work-list">
      {
        WORK.map((entry, i) => (
          <li class="work-item" style={`animation-delay: ${220 + i * 40}ms`}>
            <div class="work-meta">
              <span class="work-role">
                {entry.role} ·{" "}
                {entry.url ? (
                  <a href={entry.url} target="_blank" rel="noopener noreferrer">
                    {entry.company}
                  </a>
                ) : (
                  entry.company
                )}
              </span>
              <span class="work-period">{entry.period}</span>
            </div>
            <p class="work-desc">{entry.description}</p>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="projects">
    <header class="projects-header" style={`animation-delay: ${projectsHeaderDelay}ms`}>
      <span class="label">Projects</span>
    </header>
    <ol class="project-list">
      {
        PROJECTS.map((project, i) => (
          <li class="project-item" style={`animation-delay: ${400 + i * 35}ms`}>
            <div class="project-meta">
              {(project.url ?? project.repo) ? (
                <a
                  href={project.url ?? project.repo}
                  class="project-name"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {project.name}
                </a>
              ) : (
                <span class="project-name">{project.name}</span>
              )}
              {project.repo && (
                <a
                  href={project.repo}
                  class="project-repo"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  github ↗
                </a>
              )}
            </div>
            <p class="project-desc">{project.description}</p>
            <div class="project-stack">
              {project.stack.map((tech) => (
                <span class="stack-tag">{tech}</span>
              ))}
            </div>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="posts">
    <header class="posts-header" style={`animation-delay: ${postsHeaderDelay}ms`}>
      <span class="label">Writing</span>
      {allPosts.length > 10 && <a href="/blog">All posts →</a>}
    </header>
    <ol class="post-list">
      {
        posts.slice(0, 10).map((post) => (
          <li class="post-item">
            <a
              href={`/blog/${post.id}`}
              class="post-title"
              transition:name={`post-title-${post.id}`}
            >
              {post.data.title}
            </a>
            <time class="post-date" datetime={post.data.pubDate.toISOString()}>
              {formatDate(post.data.pubDate)}
            </time>
          </li>
        ))
      }
    </ol>
    <p class="post-count">
      <span class="label">{posts.length}/{allPosts.length}</span>
    </p>
  </section>
</BaseLayout>

<style>
  .intro {
    padding-top: clamp(5rem, 10vw, 6rem);
    padding-bottom: clamp(2.5rem, 7vw, 4rem);
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 6vw, 3.2rem);
    font-weight: 400;
    font-style: italic;
    line-height: 1.1;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
    animation: fade-up 400ms ease-out both;
  }

  .intro p {
    font-size: 0.925rem;
    color: var(--muted);
    max-width: 69ch;
    line-height: 1.7;
    animation: fade-up 400ms ease-out 100ms both;
  }

  .intro p a {
    color: var(--fg);
    text-decoration-color: var(--border);
    font-weight: 500;
  }

  .intro p a:hover {
    text-decoration-color: var(--fg);
  }

  .posts {
    padding-bottom: 2rem;
  }

  .posts-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
    animation: fade-up 400ms ease-out both;
  }

  .post-count {
    width: 100%;
    text-align: right;
    margin-top: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted);
    animation: fade-up 400ms ease-out 350ms both;
  }

  .label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .posts-header a {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .posts-header a:hover {
    color: var(--fg);
  }

  .post-list {
    list-style: none;
  }

  .post-item {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--border);
    animation: fade-up 300ms ease-out both;
  }

  .post-item:nth-child(1) {
    animation-delay: 260ms;
  }
  .post-item:nth-child(2) {
    animation-delay: 295ms;
  }
  .post-item:nth-child(3) {
    animation-delay: 330ms;
  }
  .post-item:nth-child(4) {
    animation-delay: 365ms;
  }
  .post-item:nth-child(5) {
    animation-delay: 400ms;
  }
  .post-item:nth-child(6) {
    animation-delay: 435ms;
  }
  .post-item:nth-child(7) {
    animation-delay: 470ms;
  }
  .post-item:nth-child(8) {
    animation-delay: 505ms;
  }
  .post-item:nth-child(9) {
    animation-delay: 540ms;
  }
  .post-item:nth-child(10) {
    animation-delay: 575ms;
  }

  .post-title {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 400;
    text-decoration: none;
    color: var(--fg);
    transition: color 0.15s ease;
    line-height: 1.3;
  }

  .post-title:hover {
    color: var(--muted);
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .work {
    padding-bottom: 2rem;
  }

  .work-header {
    display: flex;
    align-items: baseline;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
    animation: fade-up 400ms ease-out 180ms both;
  }

  .work-list {
    list-style: none;
  }

  .work-item {
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--border);
    animation: fade-up 300ms ease-out both;
  }

  .work-meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .work-role {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--fg);
  }

  .work-role a {
    color: var(--fg);
    font-weight: 400;
    text-decoration-color: var(--border);
  }

  .work-role a:hover {
    text-decoration-color: var(--fg);
  }

  .work-period {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .work-desc {
    font-size: 0.875rem;
    color: var(--muted);
    margin-top: 0.35rem;
    line-height: 1.6;
  }

  .projects {
    padding-bottom: 2rem;
  }

  .projects-header {
    display: flex;
    align-items: baseline;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
    animation: fade-up 400ms ease-out both;
  }

  .project-list {
    list-style: none;
  }

  .project-item {
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--border);
    animation: fade-up 300ms ease-out both;
  }

  .project-meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .project-name {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--fg);
  }

  a.project-name {
    text-decoration: none;
    transition: color 0.15s ease;
  }

  a.project-name:hover {
    color: var(--muted);
  }

  .project-repo {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: color 0.15s ease;
  }

  .project-repo:hover {
    color: var(--fg);
  }

  .project-desc {
    font-size: 0.875rem;
    color: var(--muted);
    margin-top: 0.35rem;
    line-height: 1.6;
  }

  .project-stack {
    display: flex;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .stack-tag {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--muted);
    letter-spacing: 0.02em;
  }

  .stack-tag + .stack-tag::before {
    content: "·";
    margin: 0 0.4rem;
    color: var(--border);
  }
</style>
